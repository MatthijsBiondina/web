{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Public Gateway (Remote)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/api-gateways/public-gateway",
          "remoteRoot": "/app"
        }
      ]
    }
  ]
}
